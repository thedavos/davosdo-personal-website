---
import HeaderLink from "@components/HeaderLink.astro";
import Logo from "@components/commons/Logo.astro";
import LanguageSwitcher from "@components/commons/LanguageSwitcher.vue";
import { SITE_TITLE } from "@/consts";

const navItems = [
	{ href: "/", label: "Sobre mi" },
	{ href: "/services", label: "Servicios" },
	{ href: "/experience", label: "Experiencia" },
	{ href: "/projects", label: "Proyectos" },
	{ href: "/blog", label: "Blog" },
	{ href: "/contact", label: "Contacto" },
];
---

<header>
	<nav
		class="flex min-h-[65px] flex-wrap items-center justify-between gap-4 border-b border-border bg-surface px-8 shadow-sm"
	>
		<Logo siteTitle={SITE_TITLE} />
		<div
			class="flex flex-1 flex-wrap items-center justify-center gap-x-6 gap-y-1"
		>
			{
				navItems.map((item) => (
					<HeaderLink href={item.href} class="nav-link">
						{item.label}
					</HeaderLink>
				))
			}
		</div>
		<div class="hidden items-center text-muted md:flex">
			<LanguageSwitcher client:load />
		</div>
	</nav>
</header>
<style>
	.nav-link {
		@apply px-2 py-4;
	}

	.social-link {
		@apply flex text-muted hover:text-primary;
	}
</style>
