---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"a">;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
const subpath = pathname.match(/[^\/]+/g);
const isPageActive =
	typeof href === "string" &&
	(href === pathname || href === "/" + (subpath?.[0] || ""));
---

<a
	href={href}
	aria-current={isPageActive ? "page" : undefined}
	class:list={["header-link", className, isPageActive && "header-link--active"]}
	{...props}
>
	<slot />
</a>

<style>
	.header-link {
		@apply inline-flex items-center rounded-full px-3 py-2 no-underline text-sm font-medium text-body transition-colors;
		letter-spacing: -0.25px;
	}

	.header-link:hover {
		background: rgba(99, 102, 241, 0.08);
		color: var(--color-primary);
	}

	.header-link:focus-visible {
		outline: 2px solid rgba(99, 102, 241, 0.35);
		outline-offset: 3px;
	}

	.header-link--active {
		color: var(--color-primary);
		font-weight: 700;
	}
</style>
