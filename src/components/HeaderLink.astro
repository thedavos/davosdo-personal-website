---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"a">;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
const subpath = pathname.match(/[^\/]+/g);
const isPageActive =
	typeof href === "string" && (href === pathname || href === "/" + (subpath?.[0] || ""));
---

<a
	href={href}
	aria-current={isPageActive ? "page" : undefined}
	class:list={["header-link", className, isPageActive && "header-link--active"]}
	{...props}
>
	<slot />
</a>

<style>
	.header-link {
		@apply inline-block relative no-underline transition-colors text-body hover:text-primary text-sm;
		letter-spacing: -0.35px;
	}

	.header-link--active {
		@apply text-primary border-b-primary font-semibold;
	}

	.header-link--active::after {
		@apply bg-primary absolute;
		content: "";
		height: 3px;
		bottom: 10px;
		left: 10%;
		right: 10%;
	}
</style>
