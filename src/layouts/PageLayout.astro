---
import BaseHead from "@components/BaseHead.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";

interface Props {
	title: string;
	description: string;
	lang?: string;
	containerClass?: string;
	centerContent?: boolean;
	showFooter?: boolean;
}

const {
	title,
	description,
	lang = "es",
	containerClass = "w-full max-w-[720px] lg:max-w-[1024px] mx-auto px-4 py-12",
	centerContent = false,
	showFooter = false,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={title} description={description} />
		<slot name="head" />
	</head>
	<body class="min-h-screen flex flex-col">
		<Header />
		<main class:list={["flex flex-1", centerContent && "items-center"]}>
			<div class={containerClass}>
				<slot />
			</div>
		</main>
		{showFooter && <Footer />}
	</body>
</html>
