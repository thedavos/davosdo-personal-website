---
import PageLayout from "@layouts/PageLayout.astro";
import SocialLinks from "@components/commons/SocialLinks.astro";
---

<PageLayout
	title="Contacto | davosdo.dev"
	description="Canales de contacto y redes para conectar con David Vargas."
>
	<h1>Contacto</h1>
	<p>
		Si quieres conversar sobre una oportunidad, una colaboración o un producto
		que necesite una base frontend sólida, este será el punto de entrada.
	</p>

	<section>
		<h2>Hablemos</h2>
		<p>
			Puedes escribirme por correo o encontrarme en mis redes profesionales.
		</p>
		<SocialLinks class="mt-4 flex flex-wrap gap-3" />
	</section>
</PageLayout>
