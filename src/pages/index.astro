---
import Button from "@components/commons/Button.astro";
import SocialLinks from "@components/commons/SocialLinks.astro";
import PageLayout from "@layouts/PageLayout.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "@/consts";
---

<PageLayout
	title={SITE_TITLE}
	description={SITE_DESCRIPTION}
	centerContent={true}
>
	<h1>Hola, soy David Vargas Domínguez</h1>
	<h2>Software Engineer</h2>
	<p>
		Construyo productos web y móviles escalables con foco en frontend,
		rendimiento y experiencia de usuario.
	</p>

	<div>
		<Button rightIcon="i-lucide-arrow-right">Ver proyectos</Button>
		<Button variant="ghost">Hablemos</Button>
	</div>

	<SocialLinks class="mt-4 flex flex-wrap gap-3" />
</PageLayout>
